<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="ru.jobhunter.ui.controller.AutoResponsesController"
            fitToWidth="true"
            hbarPolicy="NEVER"
            style="-fx-background: #F5F7FA; -fx-background-color: #F5F7FA;">

    <content>
        <VBox spacing="18"
              alignment="TOP_LEFT"
              style="-fx-background-color: #F5F7FA;">

            <padding>
                <Insets top="28" right="36" bottom="28" left="36"/>
            </padding>

            <Label text="Автоотклики"
                   style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #1F2937;"/>

            <Label text="Поиск вакансий, подготовка очереди и запуск автоматических откликов в одном экране."
                   wrapText="true"
                   style="-fx-font-size: 14px; -fx-text-fill: #6B7280;"/>

            <!-- Подготовка -->
            <TitledPane text="Подготовка к автооткликам"
                        expanded="true"
                        collapsible="true"
                        animated="true"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;">
                <content>
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-padding: 18;">

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label text="Резюме для автооткликов:"
                                   style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                            <Label fx:id="resumeStatusLabel"
                                   text="Основное резюме не загружено."
                                   wrapText="true"
                                   maxWidth="540"
                                   style="-fx-font-size: 13px; -fx-text-fill: #6B7280;"/>

                            <Button fx:id="resumeUploadPdfButton"
                                    text="Заменить PDF"
                                    onAction="#onUploadResumePdfClicked"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;"/>
                        </HBox>

                        <TitledPane text="Общее сопроводительное письмо (fallback)"
                                    expanded="false"
                                    collapsible="true"
                                    animated="true"
                                    style="-fx-font-size: 13px; -fx-font-weight: bold;">
                            <content>
                                <VBox spacing="10"
                                      style="-fx-background-color: #FAFAFA; -fx-background-radius: 8; -fx-border-color: #E5E7EB; -fx-border-radius: 8; -fx-padding: 14;">

                                    <Label text="Используется только как fallback, когда LLM временно недоступна. Это письмо не заменяет обычную логику отклика и будет применяться только при включённом флаге."
                                           wrapText="true"
                                           maxWidth="780"
                                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>

                                    <TextArea fx:id="generalCoverLetterTextArea"
                                              promptText="Вставьте общее сопроводительное письмо или загрузите TXT-файл..."
                                              prefRowCount="6"
                                              wrapText="true"
                                              style="-fx-background-radius: 8; -fx-border-radius: 8;"/>

                                    <HBox spacing="10" alignment="CENTER_LEFT">
                                        <CheckBox fx:id="useGeneralCoverLetterWhenLlmUnavailableCheckBox"
                                                  text="Использовать при временной недоступности LLM"/>

                                        <Button fx:id="loadGeneralCoverLetterTextButton"
                                                text="Загрузить TXT"
                                                onAction="#onLoadGeneralCoverLetterTextClicked"
                                                style="-fx-background-color: #F3F4F6; -fx-background-radius: 8; -fx-border-color: #D1D5DB; -fx-border-radius: 8;"/>

                                        <Button fx:id="saveGeneralCoverLetterButton"
                                                text="Сохранить письмо"
                                                onAction="#onSaveGeneralCoverLetterClicked"
                                                style="-fx-background-color: #E8F0FE; -fx-text-fill: #1D4ED8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BFDBFE; -fx-border-radius: 8;"/>
                                    </HBox>

                                    <Label fx:id="generalCoverLetterStatusLabel"
                                           text="Общее сопроводительное письмо ещё не сохранено."
                                           wrapText="true"
                                           maxWidth="780"
                                           style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>
                                </VBox>
                            </content>
                        </TitledPane>
                    </VBox>
                </content>
            </TitledPane>

            <!-- Поиск вакансий -->
            <TitledPane text="Поиск вакансий"
                        expanded="true"
                        collapsible="true"
                        animated="true"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;">
                <content>
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-padding: 18;">

                        <HBox spacing="12" alignment="BOTTOM_LEFT">
                            <VBox spacing="6">
                                <Label text="Платформа"
                                       style="-fx-font-size: 12px; -fx-text-fill: #4B5563;"/>
                                <ComboBox fx:id="platformComboBox"
                                          prefWidth="170"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Ключевые слова"
                                       style="-fx-font-size: 12px; -fx-text-fill: #4B5563;"/>
                                <TextField fx:id="searchTextField"
                                           promptText="Например: Java backend"
                                           prefWidth="320"/>
                            </VBox>

                            <VBox spacing="6">
                                <Label text="Регион HH area id"
                                       style="-fx-font-size: 12px; -fx-text-fill: #4B5563;"/>
                                <TextField fx:id="areaTextField"
                                           promptText="113"
                                           prefWidth="140"/>
                            </VBox>

                            <Button fx:id="searchButton"
                                    text="Найти"
                                    onAction="#onSearchClicked"
                                    prefWidth="110"
                                    style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Label fx:id="searchStatusLabel"
                                   text="Выберите платформу, введите запрос и нажмите «Найти»."
                                   wrapText="true"
                                   maxWidth="700"
                                   style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>

                            <Label fx:id="resultCountLabel"
                                   text=""
                                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="previousPageButton"
                                    text="← Назад"
                                    onAction="#onPreviousPageClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Label fx:id="paginationLabel"
                                   text="Страница —"
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>

                            <Button fx:id="nextPageButton"
                                    text="Вперёд →"
                                    onAction="#onNextPageClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Label text="На странице:"
                                   style="-fx-text-fill: #4B5563;"/>

                            <ComboBox fx:id="pageSizeComboBox"
                                      prefWidth="90"
                                      onAction="#onPageSizeChanged"/>
                        </HBox>

                        <Label text="Найденные вакансии"
                               style="-fx-font-size: 15px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <CheckBox fx:id="selectAllVacanciesCheckBox"
                                      text="Выбрать все на странице"/>

                            <Label fx:id="selectedVacancyCountLabel"
                                   text="Выбрано: 0"
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                        </HBox>

                        <ListView fx:id="vacanciesListView"
                                  prefHeight="220"/>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <Button fx:id="openVacancyButton"
                                    text="Открыть вакансию"
                                    onAction="#onOpenVacancyClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="addToQueueButton"
                                    text="Добавить выбранные в очередь"
                                    onAction="#onAddToQueueClicked"
                                    disable="true"
                                    style="-fx-background-color: #E8F0FE; -fx-text-fill: #1D4ED8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BFDBFE; -fx-border-radius: 8;"/>
                        </HBox>
                    </VBox>
                </content>
            </TitledPane>

            <!-- Очередь -->
            <TitledPane text="Очередь автооткликов"
                        expanded="true"
                        collapsible="true"
                        animated="true"
                        style="-fx-font-size: 14px; -fx-font-weight: bold;">
                <content>
                    <VBox spacing="14"
                          style="-fx-background-color: white; -fx-background-radius: 10; -fx-border-color: #E5E7EB; -fx-border-radius: 10; -fx-padding: 18;">

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="refreshQueueButton"
                                    text="Обновить очередь"
                                    onAction="#onRefreshQueueClicked"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="showReadyQueueButton"
                                    text="Показать готовые"
                                    onAction="#onShowReadyQueueClicked"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="startReadyAutoResponsesBatchButton"
                                    text="Запустить все готовые"
                                    onAction="#onStartReadyAutoResponsesBatchClicked"
                                    style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8;"/>
                        </HBox>

                        <HBox spacing="12" alignment="CENTER_LEFT">
                            <CheckBox fx:id="selectAllQueuedQueueItemsCheckBox"
                                      text="Выбрать все вакансии в очереди"/>

                            <Label fx:id="selectedQueuedQueueItemCountLabel"
                                   text="Выбрано: 0"
                                   style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>

                            <Button fx:id="markSelectedQueueItemsReadyButton"
                                    text="Пометить выбранные готовыми"
                                    onAction="#onMarkSelectedQueueItemsReadyClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>
                        </HBox>

                        <Label fx:id="batchProgressLabel"
                               text="Массовый запуск не выполняется."
                               wrapText="true"
                               maxWidth="780"
                               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #2563EB;"/>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="executeAutoResponseButton"
                                    text="Запустить автоотклик"
                                    onAction="#onExecuteAutoResponseClicked"
                                    disable="true"
                                    style="-fx-background-color: #E8F0FE; -fx-text-fill: #1D4ED8; -fx-font-weight: bold; -fx-background-radius: 8; -fx-border-color: #BFDBFE; -fx-border-radius: 8;"/>

                            <Button fx:id="markQueueItemReadyButton"
                                    text="Пометить готовой"
                                    onAction="#onMarkQueueItemReadyClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="returnQueueItemButton"
                                    text="Вернуть в очередь"
                                    onAction="#onReturnQueueItemToQueuedClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="skipQueueItemButton"
                                    text="Пропустить"
                                    onAction="#onSkipQueueItemClicked"
                                    disable="true"
                                    style="-fx-background-color: #F3F4F6; -fx-background-radius: 8;"/>

                            <Button fx:id="removeQueueItemButton"
                                    text="Удалить из очереди"
                                    onAction="#onRemoveQueueItemClicked"
                                    disable="true"
                                    style="-fx-background-color: #FEF2F2; -fx-text-fill: #B91C1C; -fx-background-radius: 8; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>
                        </HBox>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Button fx:id="copyQueueVacancyIdButton"
                                    text="Копировать ID HH"
                                    onAction="#onCopyQueueVacancyIdClicked"
                                    disable="true"
                                    style="-fx-background-color: #F9FAFB; -fx-background-radius: 8;"/>

                            <Button fx:id="openQueueVacancyButton"
                                    text="Открыть вакансию"
                                    onAction="#onOpenQueueVacancyClicked"
                                    disable="true"
                                    style="-fx-background-color: #F9FAFB; -fx-background-radius: 8;"/>

                            <Button fx:id="openQueueDiagnosticsButton"
                                    text="Открыть диагностику"
                                    onAction="#onOpenQueueDiagnosticsClicked"
                                    disable="true"
                                    style="-fx-background-color: #F9FAFB; -fx-background-radius: 8;"/>
                        </HBox>

                        <Label fx:id="queueStatusLabel"
                               text="Очередь еще не загружена."
                               wrapText="true"
                               maxWidth="780"
                               style="-fx-font-size: 12px; -fx-text-fill: #6B7280;"/>

                        <ListView fx:id="queueListView"
                                  prefHeight="210"/>
                    </VBox>
                </content>
            </TitledPane>

        </VBox>
    </content>
</ScrollPane>